# ════════════════════════════════════════════════════════════════════════════
# 標籤說明（每個變數只會有其中一種標籤）
#   [必填]              無條件必填，任何情況下都要設定
#   [必填｜條件: ...]    只有在條件成立時才必填；條件不成立時可以不填
#   [選填｜預設: ...]    可以不填，程式會使用列出的預設值
#
# 啟動時會依目前的 feature flag / 設備 / FIAS 模式自動驗證下列變數，
# 缺漏或填錯會在開機當下一次列出並終止服務（不會等到執行期才出錯）。
# ════════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────────────
# 通用設定
# ────────────────────────────────────────────────────────────────────────────

# [必填] 自動外播功能
ENABLE_OUTBOUND_CAMPAIGN=true
# [必填] 自動語音通知 (Call Schedule)
ENABLE_CALL_SCHEDULE=true

# [選填｜預設: development] 執行環境
NODE_ENV=production

# [選填｜預設: 4020] 應用服務埠
HTTP_PORT=4020

# [選填｜預設: Asia/Taipei] 日誌時間時區設定
LOG_TIMEZONE=Asia/Taipei

# [選填｜預設: 回退 Bonsale timezoneIANA，再回退 UTC]
# 業務時區設定（call-schedule 排程 / FIAS 叫醒時間轉換用），優先於 Bonsale timezoneIANA
SITE_TIMEZONE=Asia/Taipei

# ────────────────────────────────────────────────────────────────────────────
# 自動外播 Outbound Campaign（以下僅於 ENABLE_OUTBOUND_CAMPAIGN=true 時使用）
# ────────────────────────────────────────────────────────────────────────────

# [必填｜條件: ENABLE_OUTBOUND_CAMPAIGN=true] Bonsale API 連接設定
BONSALE_HOST=https://your-bonsale-api-endpoint/service
BONSALE_X_API_KEY=<YOUR_API_KEY>
BONSALE_X_API_SECRET=<YOUR_API_SECRET>

# [必填｜條件: ENABLE_OUTBOUND_CAMPAIGN=true] 3CX 系統連接
HTTP_HOST_3CX=https://your-3cx-host
WS_HOST_3CX=wss://your-3cx-host

# [必填｜條件: ENABLE_OUTBOUND_CAMPAIGN=true] AI 訊息服務（給 PY 用）
HTTP_HOST_MESSAGE_FOR_AI=http://{your-message-service-host}:8510

# [必填｜條件: ENABLE_OUTBOUND_CAMPAIGN=true] post 9000 認證設定（21 世紀用）
# credit 的用這組；21finance 的請改填對應的 Basic Auth 字串
POST_9000_BASIC_AUTH=your-post-9000-basic-auth

# [選填｜預設: false] 服務器重啟時是否自動恢復撥打任務
AUTO_RECOVER_ON_RESTART=true

# [選填｜預設: Wextension] 預設支援的呼叫者類型，逗號分隔串接
# 目前支援的類型有：Wqueue, Wextension, Wroutepoint
DEFAULT_SUPPORTED_CALL_TYPES=Wextension

# [選填｜預設: false] 是否啟用空閒檢查功能
# 啟用後，當撥號名單太久沒撥號時，系統會自動檢查並嘗試恢復撥號
IS_STARTIDLECHECK=true

# [選填｜預設: 30000] 當前檢查間隔（毫秒）
IDLE_CHECK_INTERVAL=30000
# [選填｜預設: 30000] 最小檢查間隔（毫秒）
MIN_IDLE_CHECK_INTERVAL=30000
# [選填｜預設: 300000] 最大檢查間隔（毫秒）
MAX_IDLE_CHECK_INTERVAL=300000
# [選填｜預設: 1.5] 指數退避倍數
IDLE_CHECK_BACKOFF_FACTOR=1.5

# [選填｜預設: redis://localhost:6379] Redis 連接設定
REDIS_URL=redis://{your-redis-service-host}:6379

# ────────────────────────────────────────────────────────────────────────────
# 自動語音通知 Call Schedule（以下僅於 ENABLE_CALL_SCHEDULE=true 時使用）
# ────────────────────────────────────────────────────────────────────────────

# [必填｜條件: ENABLE_CALL_SCHEDULE=true] 電話設備選擇
# 無預設值，必須明確指定 NewRock、Yeastar 或 FreeSwitch 其中一種
TELEPHONE_EQUIPMENT=FreeSwitch

# [選填｜預設: 4022] OM 事件監聽 Port（接收設備 Push 通知）
OM_MONITOR_PORT=4022

# [選填｜預設: 9038] 外播主叫分機號碼
OM_CALL_FROM_EXTENSION=9038

# [選填｜預設: 空字串＝不限制 IP] Lakeshore 通話結果回報 IP 白名單，逗號分隔串接
LAKESHORE_IP_WHITELIST=

# --- NewRock 設定 [必填｜條件: TELEPHONE_EQUIPMENT=NewRock] ---
NEW_ROCK_API_HOST=<YOUR_NEW_ROCK_API_HOST>
NEW_ROCK_API_PATH=/xml

# --- Yeastar 設定 [必填｜條件: TELEPHONE_EQUIPMENT=Yeastar] ---
YEASTAR_API_HOST=<YOUR_YEASTAR_API_HOST>
YEASTAR_API_PATH=/openapi/v1.0
YEASTAR_USERNAME=<YOUR_YEASTAR_USERNAME>
YEASTAR_PASSWORD=<YOUR_YEASTAR_PASSWORD>

# --- FreeSwitch 設定 ---
# py-dialer：morning call 撥號服務
# [必填｜條件: TELEPHONE_EQUIPMENT=FreeSwitch]
FREESWITCH_API_URL=http://127.0.0.1:5002
# [選填｜預設: 內建預設 API Key，正式環境請務必覆蓋]
FREESWITCH_API_KEY=<YOUR_FREESWITCH_API_KEY>
# [必填｜條件: TELEPHONE_EQUIPMENT=FreeSwitch] 本服務對外可達的網址（不含路徑），
# 撥號時組成 callback_url 讓 middleware 回呼通話結果（例如 Cloud Run 網址）；
# 本地開發要收到回呼需搭配 ngrok 等通道
FREESWITCH_CALLBACK_BASE_URL=https://your-backend-public-host

# --- FreeSwitch PMS Middleware 設定（Lakeshore Check-in/Check-out 用，見 docs/FIAS_INTEGRATION.md）---
# cdr-webhook：check-in/check-out 時更新 FusionPBX 分機權限與 Caller ID 的服務
# [選填｜預設: http://127.0.0.1:5001]
FREESWITCH_PMS_API_URL=http://127.0.0.1:5001
# [必填｜條件: TELEPHONE_EQUIPMENT=FreeSwitch]
FREESWITCH_PMS_API_KEY=<YOUR_FREESWITCH_PMS_API_KEY>
# [必填｜條件: TELEPHONE_EQUIPMENT=FreeSwitch] FusionPBX 的 SIP domain（例如 rtc.sbc.telesale.org）
FREESWITCH_PMS_DOMAIN_NAME=<YOUR_FUSIONPBX_DOMAIN_NAME>

# ────────────────────────────────────────────────────────────────────────────
# FIAS PMS 整合（飯店叫醒服務，以下僅於 ENABLE_CALL_SCHEDULE=true 且
# ENABLE_FIAS 不為 false 時使用；PMS 通訊協定固定為 FIAS）
# ────────────────────────────────────────────────────────────────────────────

# [選填｜預設: true] 是否啟用 FIAS
ENABLE_FIAS=true

# [選填｜預設: 空字串] 房間號碼轉分機時加的前綴（例如填 9 → 房間 101 對應分機 9101）
FIAS_EXTENSION_PREFIX=

# [選填｜預設: server｜可選值: server / client] FIAS 連線模式：
#   server：我方開 TCP server，等 PMS 連入（PMS CLIENT 模式）
#   client：我方主動連至 PMS TCP server（PMS SERVER 模式，例如 FidServ Socket Server）
FIAS_MODE=server

# [選填｜預設: 4021] FIAS_MODE=server 時：我方監聽的 TCP port
FIAS_PORT=4021

# [必填｜條件: FIAS_MODE=client] PMS TCP server 的位址與 port
# 範例：FidServ Device Settings → Device Type: Socket Server, Port: 5006
# 注意：PMS 端需勾選「allow new connection」才能接受我方連線
FIAS_PMS_HOST=<PMS_IP_OR_HOSTNAME>
FIAS_PMS_PORT=<PMS_PORT>

# [選填｜預設: 0＝停用] FIAS_MODE=client 時：主動送 LS 做 alive-check 的間隔（毫秒）
# 依 Oracle FIAS 規格 Alive-Check 章節建議，不要設得比 300000（5 分鐘）更頻繁
FIAS_HEARTBEAT_INTERVAL_MS=0

# [選填｜預設: utf8] FIAS 文字編碼
# 依 PMS 廠商設定調整：cp936（簡中 GBK）、big5（繁中）、shift_jis（日文）、latin1（歐美）
FIAS_ENCODING=utf8
